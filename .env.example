PORT=8080
HOST=0.0.0.0
NODE_ENV=development
LOG_LEVEL=info
LOG_FILE_PATH=./log.txt

# Database
DB_PATH=./nostr-claw.sqlite

# Nostr relays
NOSTR_RELAYS=wss://relay.damus.io,wss://relay.primal.net,wss://nos.lol

AI_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini

# Optional Nostr DM notifications for matched insights
NOTIFY_RECIPIENT_NPUB=

# Poll/watchlist refresh frequency
WATCHLIST_REFRESH_MS=15000

# Max AI requests per minute (0 = unlimited)
AI_RPM=20
